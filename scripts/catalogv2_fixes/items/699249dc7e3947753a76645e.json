  "content": {
    "prompt": "Napisati program koji za svaku kolonu ispisuje najve\u0107i element koji se nalazi u njoj.",
    "source_code": "#include <stdio.h>\r\n#define DIM 4\r\n\r\nint main() {\r\n    int i, j, max;\r\n    int matrica[DIM][DIM] = {\r\n        {1, 2, 3, 4},\r\n        {6, 7, 8, 9},\r\n        {8, 7, 6, 5},\r\n        {3, 2, 1, 1}\r\n    };\r\n\r\n    printf(\"Najve\u0107i elementi po kolonama:\\n\");\r\n    for (j = 0; j < DIM; j++) {\r\n        max = matrica[0][j];\r\n        for (i = 1; i < DIM; i++) {\r\n            if (matrica[i][j] > max) max = matrica[i][j];\r\n        }\r\n        printf(\"%d \", max);\r\n    }\r\n\r\n    return 0;\r\n}"
  },
