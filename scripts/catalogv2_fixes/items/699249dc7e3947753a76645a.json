  "content": {
    "prompt": "Napisati program koji ispisuje zbir elemenata u svakom redu matrice.",
    "source_code": "#include <stdio.h>\r\n#define DIM 5\r\n\r\nint main() {\r\n    int i, j, zbir;\r\n    int matrica[DIM][DIM] = {\r\n        {1, 2, 3, 4, 5},\r\n        {6, 7, 8, 9, 9},\r\n        {8, 7, 6, 5, 4},\r\n        {3, 2, 1, 1, 2},\r\n        {3, 4, 5, 6, 7}\r\n    };\r\n\r\n    printf(\"Zbir elemenata po redovima:\\n\");\r\n    for (i = 0; i < DIM; i++) {\r\n        zbir = 0;\r\n        for (j = 0; j < DIM; j++) {\r\n            zbir += matrica[i][j];\r\n        }\r\n        printf(\"Red %d: %d\\n\", i, zbir);\r\n    }\r\n\r\n    return 0;\r\n}"
  },
