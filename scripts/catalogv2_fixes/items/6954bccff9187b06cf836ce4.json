  "content": {
    "prompt": "Construct a program that prints the full name with middle initial for the name \"John Phillip Smith\".",
    "source_code": "public class Initials2\n{\n\tpublic static void main(String[] args)\n\t{\n\t\t//Step 1: Define the name\n\t\tString fullName = \"John Phillip Smith\";\n\t\t//Step 2: Extract the first name\n\t\tString first = fullName.substring(0, 4);\n\t\t//Step 3: Extract the middle initial\n\t\tString middleInitial = fullName.substring(5, 6);\n\t\t//Step 4: Extract the last name\n\t\tString last = fullName.substring(13, fullName.length());\n\t\t//Step 5: Create the name from the first name, middle initial, and last name\n\t\tString name = first + \" \" + middleInitial + \". \" + last;\n\t\tSystem.out.println(name);\n\t}\n}"
  },
