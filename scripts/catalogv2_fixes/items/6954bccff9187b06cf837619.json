    "source_code": "#include <stdio.h>\r\nstruct card { \r\n   char *face;\r\n   char *suit;\r\n};\r\nint main()\r\n{ \r\n   struct card a;\r\n   struct card *aPtr;\r\n   a.face = \"Ace\";\r\n   a.suit = \"Spades\";\r\n   aPtr = &a;\r\n   printf( \"%s%s%s\\n%s%s%s\\n%s%s%s\\n\", \r\n          a.face, \" of \", a.suit,\r\n          aPtr->face, \" of \", aPtr->suit,\r\n          ( *aPtr ).face, \" of \", ( *aPtr ).suit );\r\n   return 0;\r\n}\r\n}\r"
