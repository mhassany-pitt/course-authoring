  "content": {
    "prompt": "Construct a program that determines whether an integer is positive, negative, or zero.",
    "source_code": "import java.util.Scanner;\npublic class JIfElseNumSign1 {\n\tpublic static void main(String[] args) {\n\t\t//Step 1: Read the integer \n\t\tScanner scan = new Scanner(System.in);\n\t\tSystem.out.println(\"Enter an integer: \");\n\t\tint num = scan.nextInt();\t\t\n\t\tscan.close();\n\t\t//Step 2: Determine whether the integer is positive, negative, or zero\n\t\tif (num > 0) {\n\t\t\tSystem.out.println(\"The integer is positive.\");\n\t\t} else if (num < 0) {\n\t\t\tSystem.out.println(\"The integer is negative.\");\n\t\t} else {\n\t\t\tSystem.out.println(\"The integer is zero.\");\n\t\t}\n\t}\n}"
  },
