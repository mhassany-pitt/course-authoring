  "content": {
    "prompt": "Construct a program to write out the squares of even positive integers less than or equal to 10.",
    "source_code": "public class JWriteSquaresEven {\n\tpublic static void main(String[] args) {\n\t\t//Step 1: Iterate through the numbers in the sequence\n\t\tfor (int num = 2; num <= 10; num += 2) {\n\t\t\t//Step 1.1: Square and print each number in the sequence\n\t\t\tSystem.out.println(num + \" squared = \" + (num * num));\n\t\t}\n\t}\n}"
  },
