  "content": {
    "prompt": "This function implements a recursive version of Binary Search",
    "source_code": "def binary_search_rec(arr, target, left=None, right=None):\r\n    if left is None:\r\n        left = 0\r\n    if right is None:\r\n        right = len(arr)\r\n    if left > right:\r\n        return -1\r\n\r\n    mid = (left + right) // 2\r\n\r\n    if arr[mid] == target:\r\n        return mid\r\n    elif arr[mid] < target:\r\n        return binary_search_rec(arr, target, mid + 1, right)\r\n    else:\r\n        return binary_search_rec(arr, target, left, mid - 1)\r\nnumbers = [1, 3, 5, 7, 9, 11, 13]\r\nprint (binary_search_rec(numbers, 7))"
  },
