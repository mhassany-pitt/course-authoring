  "content": {
    "prompt": "Napisati program koji ispisuje proizvod svih elemenata na glavnoj i sporednoj dijagonali matrice dimenzija 4x4.",
    "source_code": "#include <stdio.h>\r\n#define DIM 4\r\n\r\nint main() {\r\n    int i;\r\n    long int proizvod = 1;\r\n    int matrica[DIM][DIM] = {\r\n        {1, 2, 3, 4},\r\n        {6, 7, 8, 9},\r\n        {8, 7, 6, 5},\r\n        {3, 2, 1, 1}\r\n    };\r\n\r\n    for(i = 0; i < DIM; i++){\r\n        proizvod *= matrica[i][i];\r\n        proizvod *= matrica[i][DIM-1-i];\r\n    }\r\n    \r\n    printf(\"Proizvod elemenata na glavnoj i sporednoj dijagonali je %ld\", proizvod);\r\n\r\n    return 0;\r\n}"
  },
