  "content": {
    "prompt": "Construct a function that receives an array and a target element to be searched in the given array. If the element is present, return its index, otherwise return -1.",
    "source_code": "def binary_search(arr, target):\r\n    left = 0\r\n    right = len(arr) - 1\r\n\r\n    while left <= right:\r\n        mid = (left + right) // 2\r\n\r\n        if arr[mid] == target:\r\n            return mid\r\n        elif arr[mid] < target:\r\n            left = mid + 1\r\n        else:\r\n            right = mid - 1\r\n    return -1\r\n    \r\nnumbers = [1, 3, 5, 7, 9, 11, 13]\r\nprint(binary_search(numbers, 7))   "
  },
