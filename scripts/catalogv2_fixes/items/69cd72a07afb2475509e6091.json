  "content": {
    "prompt": "Napisati program koji ispisuje elemente iznad glavne dijagonale matrice, razdvojene razmakom.",
    "source_code": "#include <stdio.h>\r\n#define DIM 5\r\n\r\nint main() {\r\n    int i, j;\r\n    int matrica[DIM][DIM] = {\r\n        {1, 2, 3, 4, 5},\r\n        {6, 7, 8, 9, 9},\r\n        {8, 7, 6, 5, 4},\r\n        {3, 2, 1, 1, 2},\r\n        {3, 4, 5, 6, 7}\r\n    };\r\n\r\n    printf(\"Elementi iznad glavne dijagonale su:\\n\");\r\n    for (i = 0; i < DIM; i++) {\r\n        for (j = 0; j < DIM; j++) {\r\n            if (j > i)\r\n                printf(\"%d \", matrica[i][j]);\r\n        }\r\n    }\r\n\r\n    return 0;\r\n}"
  },
